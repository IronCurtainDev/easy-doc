{
    "name": "ironcurtaindev/easy-doc",
    "description": "A lightweight Laravel package for API documentation generation with PHP 8 Attributes support and configurable headers",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "api",
        "documentation",
        "swagger",
        "openapi",
        "postman",
        "php-attributes",
        "sdk"
    ],
    "authors": [
        {
            "name": "Easy Pack",
            "email": "support@easypack.dev"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.4",
        "illuminate/console": "^13.4",
        "illuminate/routing": "^13.4",
        "symfony/yaml": "^7.0|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "orchestra/testbench": "^11.0",
        "phpstan/phpstan": "^1.10"
    },
    "autoload": {
        "psr-4": {
            "EasyDoc\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "EasyDoc\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "EasyDoc\\EasyDocServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyze": "vendor/bin/phpstan analyse"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
